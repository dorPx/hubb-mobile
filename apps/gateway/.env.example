# Mobile gateway config — all have sane local defaults
PORT=8790
# hermes-webui base URL (the upstream this gateway wraps)
UPSTREAM_URL=http://127.0.0.1:8787
# HMAC secret for JWTs — generated and persisted to the data dir on first run if unset
JWT_SECRET=
# SQLite data directory
DATA_DIR=./data
# Access token TTL seconds (default 900 = 15 min)
ACCESS_TTL=900
# Push driver: noop | fcm  (fcm requires FCM_SERVICE_ACCOUNT_JSON path)
PUSH_DRIVER=noop
FCM_SERVICE_ACCOUNT_JSON=
